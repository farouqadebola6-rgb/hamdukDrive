# 1. Copy this file to .env
# 2. Fill in the values below

# A strong secret — your Hamduk Drive backend sends this as x-api-key
API_SECRET=hamduk-drive-secret-change-this

# Your WhatsApp driver group ID (looks like 120363XXXXXX@g.us)
# Run the server, connect, send a message in the group — it will print here
WHATSAPP_GROUP_ID=

# Port — Render sets this automatically, leave 3000 for local
PORT=3000
